# Copie para .env (cp .env.example .env). Os defaults batem com o docker-compose.
POSTGRES_USER=farmtech
POSTGRES_PASSWORD=farmtech
POSTGRES_DB=farmtech
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Alternativa: defina a URL completa e ela tem prioridade sobre as variáveis acima.
# DATABASE_URL=postgresql+psycopg2://farmtech:farmtech@localhost:5432/farmtech
